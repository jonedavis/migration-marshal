        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/check-migration.js\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
